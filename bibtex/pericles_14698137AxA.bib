title = {Traits and functions of alpine plant communities respond strongly but not always sufficiently to in situ climate change},
journal = {New Phytologist},
volume = {n/a},
number = {n/a},
pages = {},
keywords = {alpine plants, climate change, ecosystem functions, leaf–root coordination, mycorrhizal colonization, plant economics space, Plant functional traits, transplant experiment},
